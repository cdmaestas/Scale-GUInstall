#!/usr/bin/env bash
# /usr/bin/scale-guinstall — wrapper installed by the package
# Starts the Scale GUInstall backend server using the bundled venv.

set -euo pipefail

INSTALL_DIR="/usr/lib/scale-guinstall"
VENV="$INSTALL_DIR/venv"
SERVER="$INSTALL_DIR/scale-server.py"
PORT="${PORT:-5001}"

if [[ ! -f "$SERVER" ]]; then
    echo "ERROR: $SERVER not found — is scale-guinstall installed correctly?" >&2
    exit 1
fi

# Use the package venv if available; fall back to system python3
if [[ -x "$VENV/bin/python3" ]]; then
    PYTHON="$VENV/bin/python3"
else
    PYTHON="python3"
    echo "WARNING: venv not found at $VENV — using system python3" >&2
fi

echo ""
echo "Scale GUInstall — backend server"
echo "  URL  : http://127.0.0.1:$PORT"
echo "  GUI  : open Scale-GUInstall.html in your browser"
echo "  Tunnel (from workstation): ssh -L ${PORT}:127.0.0.1:${PORT} $(whoami)@$(hostname -f 2>/dev/null || hostname)"
echo "  Stop : Ctrl+C  or  systemctl stop scale-guinstall"
echo ""

PORT="$PORT" exec "$PYTHON" "$SERVER"
